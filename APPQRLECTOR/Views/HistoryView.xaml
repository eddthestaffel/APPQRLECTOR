<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             NavigationPage.HasNavigationBar="False"
             x:Class="APPQRLECTOR.Views.HistoryView"
             Title="Historial"
             BackgroundColor="{StaticResource AppBackground}">

    <VerticalStackLayout Padding="20">

        <Label Text="Historial de Escaneos"
               FontSize="26"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               TextColor="{StaticResource PrimaryBlue}"/>

        <Button Text="Limpiar historial"
                Clicked="OnClearClicked"
                BackgroundColor="{StaticResource PrimaryBlue}"
                TextColor="White"/>

        <CollectionView x:Name="historyCollection">

            <CollectionView.ItemTemplate>

                <DataTemplate>

                    <Frame BackgroundColor="{StaticResource CardBackground}"
                           Margin="5"
                           Padding="10">

                        <VerticalStackLayout>

                            <Label Text="{Binding Content}"
                                   TextColor="{StaticResource PrimaryBlue}"
                                   FontAttributes="Bold"
                                   TextDecorations="Underline">

                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnLinkTapped"/>
                                </Label.GestureRecognizers>

                            </Label>

                            <Label Text="{Binding ScanDate, StringFormat='Fecha: {0:dd/MM/yyyy HH:mm}'}"
                                   TextColor="{StaticResource TextGray}"/>
                        </VerticalStackLayout>

                    </Frame>

                </DataTemplate>

            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>

</ContentPage>
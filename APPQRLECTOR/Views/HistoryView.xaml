<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="APPQRLECTOR.Views.HistoryView"
             Title="Historial">

    <VerticalStackLayout Padding="20">

        <Label Text="Historial de escaneos"
               FontSize="24"
               HorizontalOptions="Center"/>

        <Button Text="Limpiar Historial"
                Clicked="OnClearClicked"/>  

        <CollectionView x:Name="historyCollection">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5">
                        <VerticalStackLayout>
                            <Label Text="{Binding Content}" TextColor="Black"/>
                            <Label Text="{Binding ScanDate, StringFormat='Fecha: {0:dd/MM/yyyy HH:mm}'}"
       TextColor="Black"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>